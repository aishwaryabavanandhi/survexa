# Survexa Android App — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Device Configuration ─────────────────────────────────────────────────────
# DEVICE_TYPE: 'real' or 'emulator'
DEVICE_TYPE=real

# For real device: get UDID via 'adb devices'
DEVICE_UDID=YOUR_DEVICE_UDID

# For emulator: Name of the AVD (e.g., Pixel_6_API_34)
AVD_NAME=Pixel_6_API_34

# ─── App Configuration ────────────────────────────────────────────────────────
# Path to the APK file (relative to framework root)
APK_PATH=../app-release.apk

# App package and activity (for already-installed app)
APP_PACKAGE=com.survexa.app
APP_ACTIVITY=com.survexa.app.MainActivity

# ─── Appium Server ────────────────────────────────────────────────────────────
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ─── Test Account Credentials ─────────────────────────────────────────────────
# Create a test account in the app first, then fill these in
TEST_EMAIL=testuser@survexa.test
TEST_PASSWORD=TestPassword123!
TEST_PHONE=+919876543210

# Admin account for admin panel tests
ADMIN_EMAIL=surveyforgeadmin@gmail.com
ADMIN_PASSWORD=AdminPass123!

# ─── Backend API URL (for API pre-validation before UI tests) ─────────────────
BACKEND_URL=http://localhost:5000

# ─── Appium Log Level ─────────────────────────────────────────────────────────
APPIUM_LOG_LEVEL=info

# ─── Test Timeouts (ms) ───────────────────────────────────────────────────────
ELEMENT_WAIT_TIMEOUT=15000
PAGE_LOAD_TIMEOUT=30000
IMPLICIT_WAIT=5000
