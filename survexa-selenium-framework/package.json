{
  "name": "survexa-selenium-framework",
  "version": "1.0.0",
  "description": "Production-ready E2E Selenium WebDriver automation framework for the Survexa React application.",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "mocha tests/**/*.test.js --timeout 120000 --exit",
    "test:chrome": "cross-env BROWSER=chrome mocha tests/**/*.test.js --timeout 120000 --exit",
    "test:firefox": "cross-env BROWSER=firefox mocha tests/**/*.test.js --timeout 120000 --exit",
    "test:edge": "cross-env BROWSER=edge mocha tests/**/*.test.js --timeout 120000 --exit",
    "test:e2e": "mocha tests/e2e.test.js --timeout 120000 --exit",
    "test:dynamic": "mocha tests/dynamic.test.js --timeout 120000 --exit"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "selenium-webdriver": "^4.18.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "mocha": "^10.3.0",
    "mochawesome": "^7.1.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "license": "MIT"
}
