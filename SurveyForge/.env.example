# SurveyForge frontend (Vite)
# Copy to `.env` in this folder for local development.

# API base URL (omit to default to http://localhost:5000 in api.js)
VITE_API_URL=http://localhost:5000

# Optional: Supabase (set VITE_USE_SUPABASE_AUTH=true to use Supabase Auth instead of backend JWT)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_USE_SUPABASE_AUTH=false

# Razorpay (public key only — secret stays on backend)
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxx
