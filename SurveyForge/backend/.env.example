# SurveyForge / Survexa backend
# Copy to `.env` and fill in values.

PORT=5000
NODE_ENV=development

JWT_SECRET=change-me-to-a-long-random-secret
FRONTEND_URL=http://localhost:5173

# OpenAI (optional)
OPENAI_API_KEY=

# Email OTP (Gmail App Password)
EMAIL_USER=
EMAIL_PASS=

# ── Phone OTP / SMS ─────────────────────────────────────────
# Provider: console | twilio | msg91 | firebase
SMS_PROVIDER=console

# Default region for numbers without + prefix (ISO 3166-1 alpha-2)
DEFAULT_PHONE_REGION=IN

# Twilio (server-side SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# MSG91 (India)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Firebase Admin (verify client idToken after Firebase Phone Auth on client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or single JSON string:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Razorpay (subscriptions) ────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
